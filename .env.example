# Neon / Vercel Postgres 等 Postgres 连接串（需支持 serverless，Neon 默认即可）
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"

# 生产环境用于生成二维码与绝对链接（含 https://，无末尾斜杠）
# 本地开发可不设，默认 http://localhost:3000；在 Vercel 上不设置时会回退到 https://$VERCEL_URL
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
